{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Chess Helper (chess.com)",
  "version": "1.5",
  "host_permissions": [
    "https://stockfish.online/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.chess.com/*"
      ],
      "css": [
        "style.css"
      ],
      "js": [
        "engine.js",
        "ui.js"
      ]
    }
  ]
}